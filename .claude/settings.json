{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)",
      "Bash(find:* -delete:*)",
      "Bash(find:* -exec rm:*)",
      "Bash(curl:*$:*)",
      "Bash(wget:*$:*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[System.Media.SystemSounds]::Asterisk.Play(); Start-Sleep -Milliseconds 800",
            "shell": "powershell"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[System.Media.SystemSounds]::Question.Play(); Start-Sleep -Milliseconds 800",
            "shell": "powershell"
          }
        ]
      }
    ]
  }
}
